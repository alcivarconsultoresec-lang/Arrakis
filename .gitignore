.cache
nosetests.xml
coverage.xml
*.cover
*.log
.pytest_cache/
.mypy_cache/
.hypothesis/

# Compiled and build artifacts
*.o
*.obj
*.out
*.so
*.dll
*.a
*.class

# Dependencies
node_modules/
target/
.gradle/

# Logs and temp files
*.tmp
*.swp
*.swo

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Original rules preserved
*.log
```